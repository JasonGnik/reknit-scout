{
  "name": "reknit-scout",
  "version": "0.0.1",
  "private": true,
  "description": "Reddit lead-finder for Reknit. Crawls injury subreddits, ranks high-fit posts, drafts founder-voiced replies for human approval.",
  "type": "module",
  "scripts": {
    "scout": "tsx src/index.ts",
    "scout:digest": "tsx src/index.ts --digest",
    "scout:dry": "tsx src/index.ts --dry-run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.5",
    "snoowrap": "^1.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
